# ── Google auth (pick ONE mode) ─────────────────────────────────────────────

# Mode 1 — Static access token (simplest; expires in ~1h, re-mint when it dies).
# GTM_ACCESS_TOKEN=ya29....

# Mode 2 — Refresh token (durable; auto-refreshes). See README for how to mint.
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
# GOOGLE_REFRESH_TOKEN=1//xxxx

# ── Guardrails (default: read-only) ─────────────────────────────────────────
# Opt into mutations explicitly. delete/publish/high-impact still need
# confirm:true on each call even when enabled here.
# GTM_MCP_ENABLE_WRITES=true
# GTM_MCP_ENABLE_DELETES=true
# GTM_MCP_ENABLE_PUBLISH=true

# ── Optional ────────────────────────────────────────────────────────────────
# Default Google account email to act as when a tool call omits `email`.
# MCP_GTM_EMAIL=you@example.com
