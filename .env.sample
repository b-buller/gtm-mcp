# ── Google auth ──────────────────────────────────────────────────────────────
# Recommended: run `npm run login` once (browser flow). Tokens are stored at
# ~/.config/gtm-mcp/tokens.json and none of the vars below are needed.

# Override A — Static access token (expires in ~1h; beats everything while set).
# GTM_ACCESS_TOKEN=ya29....

# Override B — Refresh token via env (beats the stored login; for CI etc.).
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
# GOOGLE_REFRESH_TOKEN=1//xxxx

# Narrow the scopes `npm run login` requests (space/comma separated; default:
# all four Tag Manager scopes).
# GTM_SCOPES=https://www.googleapis.com/auth/tagmanager.readonly

# ── Guardrails (default: read-only) ─────────────────────────────────────────
# Opt into mutations explicitly. delete/publish/high-impact still need
# confirm:true on each call even when enabled here.
# GTM_MCP_ENABLE_WRITES=true
# GTM_MCP_ENABLE_DELETES=true
# GTM_MCP_ENABLE_PUBLISH=true

# ── Optional ────────────────────────────────────────────────────────────────
# Default Google account email to act as when a tool call omits `email`.
# MCP_GTM_EMAIL=you@example.com
